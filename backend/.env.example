# ─── Backend Environment Variables ───
# Copy this file to .env and fill in your values

# JWT Secret Key (change this to a strong random string in production)
JWT_SECRET_KEY=your-secret-key-here

# MongoDB URI
# Local development:
# MONGODB_URI=mongodb://localhost:27017/logistics_db
# Production (Atlas on Render):
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/logistics_db?retryWrites=true&w=majority&appName=your-app
MONGODB_DB_NAME=logistics_db

# Optional Mongo TLS flags (leave defaults for Atlas production)
MONGODB_TLS_CA_FILE=
MONGODB_TLS_ALLOW_INVALID_CERTS=false
MONGODB_TLS_DISABLE=false

# Comma-separated list of frontend origins allowed by CORS
BACKEND_CORS_ORIGINS=http://localhost:3000,https://ai-logistics-system.vercel.app
