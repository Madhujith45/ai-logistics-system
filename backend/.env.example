# ─── Backend Environment Variables ───
# Copy this file to .env and fill in your values

# JWT Secret Key (change this to a strong random string in production)
JWT_SECRET_KEY=your-secret-key-here

# Database URL (default: SQLite, switch to PostgreSQL for production)
# DATABASE_URL=sqlite:///./logistics.db
# DATABASE_URL=postgresql://user:password@host:5432/logistics_db
